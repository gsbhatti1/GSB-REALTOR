{
  "expo": {
    "name": "GSB Realtor",
    "slug": "gsb-realtor",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "gsbrealtor",
    "backgroundColor": "#060606",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060606"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gsbrealtor.app",
      "buildNumber": "1",
      "requireFullScreen": true,
      "usesAppleSignIn": true,
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GSB Realtor uses your location to find nearby Utah properties.",
        "CFBundleDisplayName": "GSB Realtor",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060606"
      },
      "package": "com.gsbrealtor.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-location",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "eas": {},
      "supabaseUrl": "https://hgsxndnxyczhudhsbddo.supabase.co",
      "siteUrl": "https://www.gsbrealtor.com"
    },
    "owner": "gsbhatti1"
  }
}