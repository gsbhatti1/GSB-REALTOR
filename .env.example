# =============================================
# GSB REALTOR — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to GitHub — it is in .gitignore
# =============================================

# ─── WFRMLS / Utah Real Estate API ──────────
# Get from: vendor.utahrealestate.com → Account Summary
# Casey (Scott) will send you the bearer token
WFRMLS_BEARER_TOKEN=Bearer your_token_here

# ─── Supabase (Database) ────────────────────
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Mapbox (Maps) ──────────────────────────
# Get from: mapbox.com → Account → Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ─── Resend (Email Notifications) ───────────
# Get from: resend.com → API Keys
# First add gsbrealtor.com as a domain in Resend
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM_EMAIL=leads@gsbrealtor.com
RESEND_TO_EMAIL=gsbhatti1@yahoo.com

# ─── Twilio (SMS Notifications) ─────────────
# Get from: twilio.com → Console
# ~$1/month when leads start coming in
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1your_twilio_number
GURPREET_PHONE_NUMBER=+18016358462

# ─── Claude AI (Chatbot) ────────────────────
# Get from: console.anthropic.com → API Keys
# Powers the 24/7 AI chatbot on your site
# Optional — chatbot works without it using smart fallback
CLAUDE_API_KEY=sk-ant-your_key_here

# ─── Admin Dashboard ────────────────────────
# Password to access /admin
# Change this to something only you know
NEXT_PUBLIC_ADMIN_PASSWORD=gsbrealtor2024

# ─── Site Config ────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gsbrealtor.com
NEXT_PUBLIC_AGENT_NAME=Gurpreet Bhatti
NEXT_PUBLIC_AGENT_PHONE=801-635-8462
NEXT_PUBLIC_AGENT_EMAIL=gsbhatti1@yahoo.com
NEXT_PUBLIC_BROKERAGE=Dynasty Point Referral Group
NEXT_PUBLIC_LICENSE=12907042-SA00
